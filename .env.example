# Notion API Configuration
NOTION_TOKEN=your_notion_api_token_here
SANDBOX_PARENT_PAGE_ID=your_SANDBOX_PARENT_PAGE_ID

# Notion Database IDs
NOTION_PROJECTS_DATABASE_ID=your_projects_database_id
NOTION_PROJECTS_DATA_SOURCE_ID=your_projects_data_source_id
NOTION_TASKS_DATABASE_ID=your_tasks_database_id
NOTION_TASKS_DATA_SOURCE_ID=your_tasks_data_source_id
NOTION_INBOX_PAGE_ID=your_inbox_page_id
ID_PROJECT_PAGE_ID=project_id_for_testing
ID_UPDATE_PAGE_ID=page_id_for_testing

# Google API Configuration
GOOGLE_API_KEY=your_google_api_key_here
E2B_API_KEY=your_e2b_api_key_here

# LangSmith Configuration
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=your_project_name_here

# Poetry Configuration
POETRY_API_KEY=your_poetry_api_key_here
